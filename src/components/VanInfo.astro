---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const ICONS: Record<string, string> = {
  bed:    '<path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6M3 18h18M3 18v2M21 18v2M7 10V7a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v3"/>',
  stove:  '<rect x="4" y="4" width="16" height="16" rx="2"/><circle cx="9" cy="10" r="1.5"/><circle cx="15" cy="10" r="1.5"/><path d="M7 17h10"/>',
  shower: '<path d="M4 3v5a4 4 0 0 0 4 4h0a4 4 0 0 0 4-4V3"/><path d="M8 12v9M10 16l-2 2M6 16l2 2M10 20l-2 2M6 20l2 2"/>',
  wifi:   '<path d="M5 12a10 10 0 0 1 14 0"/><path d="M8.5 15a6 6 0 0 1 7 0"/><circle cx="12" cy="18" r="1"/>',
  solar:  '<rect x="3" y="5" width="18" height="10" rx="1"/><path d="M3 10h18M8 5v10M13 5v10"/><path d="M7 20h10"/>',
  water:  '<path d="M12 3s6 7 6 11a6 6 0 1 1-12 0c0-4 6-11 6-11z"/>',
};
---

<section class="van section">
  <div class="van__inner">
    <div class="van__media">
      <img
        src="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?w=1200&q=80"
        alt={t.home.info.imageAlt}
        class="van__img"
        loading="lazy"
      />
      <div class="van__scrim"></div>
      <div class="van__overlay">
        <span class="label-md van__label">{t.home.info.label}</span>
        <h2 class="display-md van__title">{t.home.info.title}</h2>
      </div>
    </div>

    <div class="van__content">
      <div class="van__block">
        <h3 class="title-lg">{t.home.info.specsTitle}</h3>
        <dl class="van__specs">
          {t.home.info.specs.map((s) => (
            <div class="van__spec">
              <dt class="label-sm">{s.label}</dt>
              <dd class="title-sm">{s.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="van__block">
        <h3 class="title-lg">{t.home.info.equipmentTitle}</h3>
        <ul class="van__equipment">
          {t.home.info.equipment.map((item) => (
            <li class="van__item">
              <span class="van__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[item.icon] ?? ''} />
              </span>
              <span class="body-lg">{item.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .van { background: var(--surface); }
  .van__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .van__media {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }
  .van__img { width: 100%; height: 100%; object-fit: cover; }
  .van__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, var(--surface) 100%);
  }
  .van__overlay {
    position: absolute;
    left: 2rem;
    right: 2rem;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .van__label { color: var(--tertiary); }
  .van__title { color: var(--on-surface); max-width: 14ch; }

  .van__content { display: flex; flex-direction: column; gap: 3rem; }
  .van__block { display: flex; flex-direction: column; gap: 1.25rem; }

  .van__specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 2rem;
    margin: 0;
  }
  .van__spec { display: flex; flex-direction: column; gap: 0.25rem; }
  .van__spec dt { color: var(--on-surface-variant); }
  .van__spec dd { margin: 0; color: var(--on-surface); }

  .van__equipment {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1.5rem;
  }
  .van__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--on-surface);
  }
  .van__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sm);
    background: var(--surface-container);
    color: var(--primary);
  }

  @media (min-width: 1024px) {
    .van__inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .van__media { aspect-ratio: 3/4; position: sticky; top: calc(var(--header-height) + 2rem); }
  }
</style>
