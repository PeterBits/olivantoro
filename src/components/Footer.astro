---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const DEFAULT_WHATSAPP_NUMBER = '34722185903';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? DEFAULT_WHATSAPP_NUMBER;
const whatsappHref = `https://wa.me/${whatsappNumber}`;
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__tagline title-sm">{t.footer.tagline}</p>
    <div class="footer__links">
      <a href={whatsappHref} class="footer__link footer__icon-link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <svg class="footer__icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3.01.97 4.31l-1.29 4.58 4.71-1.23C8.88 21.55 10.37 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.41 0-2.73-.35-3.88-.95l-.28-.15-2.89.75.77-2.74-.18-.29c-.68-1.14-1.05-2.47-1.05-3.85 0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8zm3.53-12.47c-.21-.11-1.25-.62-1.44-.69-.19-.07-.33-.11-.47.11-.14.22-.53.67-.65.81-.12.14-.24.16-.45.05-.21-.11-1.29-.48-2.45-1.52-.91-.82-1.51-1.82-1.69-2.03-.18-.22-.02-.33.14-.44.14-.12.31-.31.47-.46.15-.15.2-.25.3-.41.1-.16.05-.3-.025-.42-.075-.12-.47-1.13-.64-1.54-.17-.39-.34-.34-.47-.35-.12-.01-.26-.01-.4-.01-.14 0-.37.05-.56.25-.19.2-.73.72-.73 1.75 0 1.03.75 2.03.86 2.17.11.14 1.55 2.36 3.74 3.31 2.2 1.01 2.85.89 3.32.83.47-.06 1.51-.62 1.72-1.22.21-.6.21-1.12.15-1.23-.07-.11-.18-.15-.36-.27z"/>
        </svg>
      </a>
      <a href={t.footer.instagramHref} class="footer__link footer__icon-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg class="footer__icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm3.61 8.07c0 .23 0 .47 0 .73 0 3.63-2.76 7.82-7.82 7.82-1.55 0-3-.45-4.21-1.24.21.02.43.03.65.03 1.29 0 2.47-.43 3.41-1.15-1.2-.02-2.21-.81-2.57-1.89.17.03.34.05.51.05.25 0 .49-.03.73-.1-1.26-.25-2.21-1.36-2.21-2.7v-.03c.37.21.8.33 1.26.34-.74-.49-1.23-1.33-1.23-2.28 0-.5.13-.97.37-1.37 1.36 1.67 3.39 2.77 5.67 2.88-.05-.2-.07-.4-.07-.61 0-1.48 1.2-2.68 2.68-2.68.77 0 1.46.32 1.95.85.61-.12 1.18-.34 1.7-.64-.2.62-.62 1.14-1.17 1.47.54-.06 1.05-.2 1.53-.41-.36.53-.82 1-1.34 1.38z"/>
        </svg>
      </a>
    </div>
    <p class="footer__copy label-sm">{t.footer.copyright}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-container-low);
    padding: 3rem 2rem;
  }
  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--on-surface);
    font-size: 1.125rem;
  }
  .footer__links { display: flex; gap: 1.25rem; }
  .footer__link {
    color: var(--on-surface-variant);
    font-weight: 500;
    font-size: 0.875rem;
    transition: color var(--transition);
  }
  .footer__link:hover { color: var(--primary); }
  .footer__icon-link { display: flex; align-items: center; justify-content: center; }
  .footer__icon { width: 1.5rem; height: 1.5rem; }
  .footer__copy { color: var(--outline); }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
